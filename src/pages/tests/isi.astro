---
import Base from '../../layouts/Base.astro';
---
<Base title="Тест на бессонницу ISI онлайн — Владислав Басков" description="Индекс тяжести бессонницы ISI: 7 вопросов, 2 минуты. Валидированная шкала с автоматическим подсчётом. Бесплатно и анонимно.">
  <div class="page-head wrap">
    <div class="eyebrow"><a href="/tests/" style="color:inherit;text-decoration:none">← Психологические тесты</a></div>
    <h2 class="title">Индекс тяжести бессонницы (ISI)</h2>
  </div>
  <div class="wrap" style="padding-bottom:96px">
    <div id="test-root"></div>
  </div>

  <script is:inline>
window.TEST_CONFIG = {
  id: 'isi',
  title: 'Индекс тяжести бессонницы (ISI)',
  description: 'ISI (Morin) — стандартная шкала оценки бессонницы, применяется сомнологами по всему миру. Оценивайте своё состояние за ПОСЛЕДНИЕ ДВЕ НЕДЕЛИ.',
  minutes: '1–2',
  scoring: 'sum',
  valueStart: 0,
  resultNote: 'Сумма баллов: 0–7 — клинически значимой бессонницы нет; 8–14 — подпороговая бессонница; 15–21 — умеренная, стоит обратиться к специалисту; 22–28 — тяжёлая, нужна помощь врача. Важно: стойкая бессонница с дневной сонливостью может быть маской апноэ сна — пройдите также тест STOP-BANG на этой странице. Бессонница эффективно лечится, и далеко не всегда таблетками.',
  scaleLabels: ['Нет','Слегка','Умеренно','Сильно','Очень сильно'],
  bands: [
    { max: 8,  label: 'в пределах нормы', color: '#7fb069', pos: { label: 'в пределах нормы', color: '#7fb069' } },
    { max: 15, label: 'подпороговая бессонница', color: '#c9a26b', pos: { label: 'подпороговая бессонница', color: '#c9a26b' } },
    { max: 22, label: 'умеренная бессонница', color: '#d98e4a', pos: { label: 'умеренная бессонница', color: '#d98e4a' } },
    { max: 99, label: 'тяжёлая бессонница', color: '#c95b5b', pos: { label: 'тяжёлая бессонница', color: '#c95b5b' } }
  ],
  scales: {
    ins: { name: 'Тяжесть бессонницы', group: '', items: [1,2,3,4,5,6,7] }
  },
  items: [
"Насколько выражены у вас трудности с засыпанием",
"Насколько выражены трудности с поддержанием сна (частые ночные пробуждения)",
"Насколько выражена проблема слишком раннего окончательного пробуждения",
"Насколько вы неудовлетворены своим текущим сном",
"Насколько, по-вашему, проблемы со сном заметны окружающим по вашему состоянию",
"Насколько вы обеспокоены или встревожены своими проблемами со сном",
"Насколько проблемы со сном мешают вашей дневной жизни (усталость, концентрация, настроение, работоспособность)"
  ].map(function (t, i) { return { n: i + 1, text: t }; })
};
  </script>
  <script is:inline src="/test-engine.js"></script>
</Base>
