---
import Base from '../../layouts/Base.astro';
---
<Base title="Тест на тревожность GAD-7 онлайн — Владислав Басков" description="Шкала тревоги GAD-7: 7 вопросов, 2 минуты, автоматический подсчёт. Валидированный скрининг тревожного расстройства. Бесплатно и анонимно.">
  <div class="page-head wrap">
    <div class="eyebrow"><a href="/tests/" style="color:inherit;text-decoration:none">← Психологические тесты</a></div>
    <h2 class="title">Шкала тревоги GAD-7</h2>
  </div>
  <div class="wrap" style="padding-bottom:96px">
    <div id="test-root"></div>
  </div>

  <script is:inline>
window.TEST_CONFIG = {
  id: 'gad7',
  title: 'Шкала генерализованной тревоги (GAD-7)',
  description: 'GAD-7 — стандартный врачебный скрининг тревожных расстройств, применяется по всему миру в паре со шкалой депрессии PHQ-9. Оцените, как часто за ПОСЛЕДНИЕ ДВЕ НЕДЕЛИ вас беспокоило каждое из следующих состояний.',
  minutes: '1–2',
  scoring: 'sum',
  valueStart: 0,
  resultNote: 'Сумма баллов: 0–4 — тревога в пределах нормы; 5–9 — лёгкая тревожность, понаблюдайте за собой; 10–14 — умеренная, рекомендуется консультация специалиста; 15–21 — выраженная, консультация врача нужна в ближайшее время. Тревожные расстройства — одна из самых благодарных мишеней терапии: хорошо отвечают и на психотерапию (включая гипнотерапию), и при необходимости на мягкую медикаментозную поддержку. Это скрининг, а не диагноз.',
  scaleLabels: ['Ни разу','Несколько дней','Более половины дней','Почти каждый день'],
  bands: [
    { max: 5,  label: 'в пределах нормы', color: '#7fb069', pos: { label: 'в пределах нормы', color: '#7fb069' } },
    { max: 10, label: 'лёгкая тревожность', color: '#c9a26b', pos: { label: 'лёгкая тревожность', color: '#c9a26b' } },
    { max: 15, label: 'умеренная тревожность', color: '#d98e4a', pos: { label: 'умеренная тревожность', color: '#d98e4a' } },
    { max: 99, label: 'выраженная тревожность', color: '#c95b5b', pos: { label: 'выраженная тревожность', color: '#c95b5b' } }
  ],
  scales: {
    anx: { name: 'Уровень тревоги', group: '', items: [1,2,3,4,5,6,7] }
  },
  items: [
"Вы нервничали, тревожились или были на взводе",
"Вы не могли прекратить беспокоиться или контролировать беспокойство",
"Вы слишком много волновались по разным поводам",
"Вам было трудно расслабиться",
"Вы были настолько беспокойны, что не могли усидеть на месте",
"Вы легко раздражались или злились",
"Вы испытывали страх, будто может случиться что-то ужасное"
  ].map(function (t, i) { return { n: i + 1, text: t }; })
};
  </script>
  <script is:inline src="/test-engine.js"></script>
</Base>
