---
import Base from '../../layouts/Base.astro';
---
<Base title="Тест на эннеатип по Наранхо онлайн — Владислав Басков" description="Определите свой эннеатип: 9 типов характера в трактовке Клаудио Наранхо, три центра, ведущая страсть. 36 вопросов, бесплатно.">
  <div class="page-head wrap">
    <div class="eyebrow"><a href="/tests/" style="color:inherit;text-decoration:none">← Психологические тесты</a></div>
    <h2 class="title">Эннеатип по Наранхо</h2>
  </div>
  <div class="wrap" style="padding-bottom:96px">
    <div id="test-root"></div>
  </div>

  <script is:inline>
window.TEST_CONFIG = {
  id: 'ennea',
  title: 'Определение эннеатипа (по Клаудио Наранхо)',
  description: 'Чилийский психиатр Клаудио Наранхо описал девять структур характера, в основе каждой — своя «страсть»: привычный эмоциональный мотор, который когда-то защищал, а теперь ограничивает. Типы распределены по трём центрам: инстинктивному, эмоциональному и ментальному. Отвечайте, каким вы бываете чаще всего на протяжении жизни, а не в лучшие свои моменты.',
  minutes: '6–8',
  resultNote: 'Ваш вероятный эннеатип — шкала с самым высоким баллом; вторая по высоте из соседних (по кругу) — «крыло», оттеняющее тип. Обратите внимание и на самый высокий центр в целом: он показывает, чем вы в первую очередь реагируете на жизнь — действием, чувством или анализом. По Наранхо тест — только рабочая гипотеза: тип точно определяется в самонаблюдении и диалоге со специалистом, потому что суть типа — не поведение, а мотив за ним. Это авторский опросник по мотивам «Характера и невроза» Наранхо, а не стандартизированная методика.',
  scaleLabels: ['Совсем не про меня','Скорее не про меня','Когда как','Скорее про меня','Точно про меня'],
  bands: [
    { max: 2.25, label: 'слабо', color: '#8a93b8', pos: { label: 'слабо', color: '#8a93b8' } },
    { max: 3.25, label: 'умеренно', color: '#a99b93', pos: { label: 'умеренно', color: '#a99b93' } },
    { max: 4.25, label: 'заметно', color: '#c9a26b', pos: { label: 'заметно', color: '#c9a26b' } },
    { max: 99,   label: 'сильно', color: '#e0c896', pos: { label: 'сильно', color: '#e0c896' } }
  ],
  scales: {
    t8: { name: 'Тип 8 · Сильный (страсть — вожделение силы)', group: 'Инстинктивный центр', items: [8,17,26,35] },
    t9: { name: 'Тип 9 · Миротворец (страсть — самозабвение)', group: 'Инстинктивный центр', items: [9,18,27,36] },
    t1: { name: 'Тип 1 · Перфекционист (страсть — гнев)', group: 'Инстинктивный центр', items: [1,10,19,28] },
