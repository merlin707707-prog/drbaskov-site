---
import Base from '../../layouts/Base.astro';

const groups = [
  {
    title: 'Настроение и тревога',
    tests: [
      { href: '/tests/gad7/', name: 'Шкала тревоги GAD-7', desc: 'Стандартный врачебный скрининг тревожности: 7 вопросов о последних двух неделях. Пара к шкале депрессии PHQ-9.', meta: '7 вопросов · 1–2 минуты' },
      { href: '/tests/phq9/', name: 'Шкала депрессии PHQ-9', desc: 'Быстрый скрининг депрессии — 9 вопросов о последних двух неделях. Один из самых валидированных опросников в мире.', meta: '9 вопросов · 2–3 минуты' },
      { href: '/tests/ocir/', name: 'Опросник навязчивостей OCI-R', desc: 'Навязчивые мысли и действия: проверки, мытьё, порядок, счёт, накопительство. Общий балл и шесть подшкал.', meta: '18 вопросов · 3–4 минуты' },
      { href: '/tests/mdq/', name: 'Скрининг биполярного расстройства (MDQ)', desc: 'Были ли периоды необычного подъёма, энергии и рискованных решений? Стандартный скрининг БАР I типа с официальными критериями.', meta: '15 вопросов · 3–4 минуты' },
      { href: '/tests/hcl32/', name: 'Опросник гипомании (HCL-32)', desc: '«Мягкие подъёмы», которые кажутся лучшими периодами жизни, — скрининг БАР II типа. Важен при депрессиях, не отвечающих на лечение.', meta: '32 вопроса · 4–5 минут' }
    ]
  },
  {
    title: 'Сон',
    tests: [
      { href: '/tests/isi/', name: 'Индекс тяжести бессонницы (ISI)', desc: 'Стандартная шкала сомнологов: засыпание, пробуждения, дневные последствия. Покажет, пора ли заниматься сном всерьёз.', meta: '7 вопросов · 1–2 минуты' },
      { href: '/tests/apnoe/', name: 'Риск апноэ сна (STOP-BANG)', desc: 'Храп, разбитость по утрам и дневная сонливость? Минута на мировой стандарт скрининга остановок дыхания во сне.', meta: '8 вопросов · 1 минута' }
    ]
  },
  {
    title: 'Внимание, энергия, выгорание',
    tests: [
      { href: '/tests/adhd/', name: 'СДВГ у взрослых (ASRS v1.1)', desc: 'Официальный скрининг ВОЗ: невнимательность, гиперактивность, импульсивность. Подсчёт по оригинальному ключу с порогами для каждой шкалы.', meta: '18 вопросов · 4–5 минут' },
      { href: '/tests/burnout/', name: 'Опросник выгорания (CBI)', desc: 'Копенгагенский опросник: отдельно измеряет общее истощение и выгорание, связанное с работой, — видно, откуда утекают силы.', meta: '13 вопросов · 3–4 минуты' }
    ]
  },
  {
    title: 'Пищевое поведение',
    tests: [
      { href: '/tests/eat26/', name: 'Отношение к еде (EAT-26)', desc: 'Мировой стандарт скрининга расстройств пищевого поведения: ограничения, переедание, контроль. Общий балл и три подшкалы.', meta: '26 вопросов · 3–4 минуты' }
    ]
  },
  {
    title: 'Личность и глубинные паттерны',
    tests: [
      { href: '/tests/sapas/', name: 'Скрининг SAPAS', desc: 'Самый быстрый тест раздела: 8 вопросов «да/нет» о том, какой вы в целом по жизни. Показывает, стоит ли смотреть глубже в сторону устойчивых личностных особенностей.', meta: '8 вопросов · 1–2 минуты' },
      { href: '/tests/lpfs/', name: 'Уровень функционирования личности (LPFS-BF 2.0)', desc: 'Две основы личностного здоровья по DSM-5: устойчивость ощущения себя и способность к близким отношениям. Дополняет профиль черт PID-5-BF.', meta: '12 вопросов · 2–3 минуты' },
      { href: '/tests/pid5/', name: 'Личностный опросник PID-5-BF', desc: 'Профиль личностных черт по современной дименсиональной модели DSM-5: пять доменов от негативной аффективности до психотизма. Русская валидированная версия.', meta: '25 вопросов · 3–5 минут' },
      { href: '/tests/ysq/', name: 'Опросник схем Янга (YSQ-S3R)', desc: '18 ранних дезадаптивных схем — глубинных убеждений, которые управляют повторяющимися жизненными сценариями. Основной инструмент диагностики в схематерапии.', meta: '90 вопросов · 10–15 минут' },
      { href: '/tests/smi/', name: 'Опросник режимов (SMI 1.1)', desc: '14 режимов — эмоциональных состояний, в которые мы «переключаемся»: от Уязвимого ребёнка и Внутреннего критика до Здорового взрослого.', meta: '124 вопроса · 15–20 минут' }
    ]
  },
  {
    title: 'Типологии и развитие',
    tests: [
      { href: '/tests/jung/', name: 'Юнгианский психотип', desc: 'Ваш тип по К. Г. Юнгу: экстраверсия или интроверсия и ведущая функция — мышление, чувство, ощущение или интуиция. Восемь классических типов.', meta: '30 вопросов · 5–7 минут' },
      { href: '/tests/enneagram/', name: 'Эннеатип по Наранхо', desc: 'Девять структур характера и их «страсти» в трактовке Клаудио Наранхо: от Перфекциониста до Миротворца. Ведущий тип, крыло и доминирующий центр.', meta: '36 вопросов · 6–8 минут' },
      { href: '/tests/socionika/', name: 'Соционика: тип ИМ по Калинаускасу', desc: '16 типов информационного метаболизма: установка, логика/этика, сенсорика/интуиция — и структура из четырёх функций, от зоны уверенности до канала внушаемости.', meta: '40 вопросов · 7–9 минут' },
      { href: '/tests/spiral/', name: 'Спиральная динамика: уровни развития', desc: 'Мемы Грейвза — Бека — Уилбера: от магического до интегрального. Два отдельных профиля — интеллектуальная и эмоциональная зрелость.', meta: '36 вопросов · 6–8 минут' }
    ]
  }
];
---
<Base title="Психологические тесты онлайн — Владислав Басков, врач-психотерапевт" description="19 профессиональных психологических тестов онлайн: тревога, депрессия, СДВГ, БАР, сон, РПП, схемы Янга, личность и типологии. Бесплатно, с автоматическим подсчётом.">
  <div class="page-head wrap">
    <div class="eyebrow">Тесты</div>
    <h2 class="title">Психологические тесты</h2>
    <p class="sub">Профессиональные опросники, которые я использую в работе. Прохождение бесплатное, результаты автоматически подсчитываются и сохраняются только в вашем браузере — я их не вижу. Если результат вас встревожил или заинтересовал — приходите, разберём вместе.</p>
  </div>
  <div class="wrap" style="padding-bottom:96px">
    {groups.map((g) => (
      <section style="padding:0;margin-top:52px">
        <h3 class="t-sec">{g.title}</h3>
        <div class="tests-cards">
          {g.tests.map((t) => (
            <div class="card">
              <h3>{t.name}</h3>
              <p>{t.desc}</p>
              <p style="margin-top:10px;font-size:13px;color:var(--gold)">{t.meta}</p>
              <a class="t-btn solid" style="margin-top:18px" href={t.href}>Пройти тест</a>
            </div>
          ))}
        </div>
      </section>
    ))}

    <div class="card" style="margin-top:56px">
      <h3>Полная диагностика — на консультации</h3>
      <p>Все тесты на этой странице — скрининговые: они показывают, куда смотреть, но не ставят диагноз. Подтверждение и точная оценка проводятся на приёме с помощью клинических методик (структурированные интервью SCID-5-PD, STiP-5.1), которые невозможно пройти онлайн. Если результаты тестов вас насторожили — <a href="/#contact" style="color:var(--gold)">запишитесь на диагностическую консультацию</a>.</p>
    </div>

    <p class="sub" style="margin-top:40px;font-size:13.5px">YSQ-S3R и SMI: © Young J. et al., русская адаптация П. М. Касьяника и Е. В. Романовой. PHQ-9 и GAD-7: © Pfizer Inc., свободное использование. PID-5-BF: © American Psychiatric Association, русская адаптация Г. В. Кустова и соавт. (2022). SAPAS: Moran et al. (2003). LPFS-BF 2.0: Weekers, Hutsebaut & Kamphuis (2019), неофициальный перевод. OCI-R: Foa et al. (2002). ISI: Morin (1993). EAT-26: Garner et al. (1982). STOP-BANG: Chung et al. (2008). CBI: Kristensen et al. (2005), неофициальный перевод. ASRS v1.1: ВОЗ / Kessler et al. (2005). MDQ: Hirschfeld et al. (2000). HCL-32: Angst et al. (2005). Соционический тест и тесты по Юнгу и Наранхо — авторские адаптации (по И. Калинаускасу «Игры, в которые играет „Мы“», К. Г. Юнгу, К. Наранхо). Тесты предназначены для самонаблюдения и не заменяют консультацию специалиста.</p>
  </div>
</Base>
