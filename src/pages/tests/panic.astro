---
import Base from '../../layouts/Base.astro';
---
<Base title="Тест на панические атаки PDSS онлайн — Владислав Басков" description="Шкала тяжести панического расстройства PDSS-SR: 7 вопросов, оценка частоты атак, тревоги и избегания. Клинический инструмент, бесплатно и анонимно.">
  <div class="page-head wrap">
    <div class="eyebrow"><a href="/tests/" style="color:inherit;text-decoration:none">← Психологические тесты</a></div>
    <h2 class="title">Тяжесть панического расстройства (PDSS-SR)</h2>
  </div>
  <div class="wrap" style="padding-bottom:96px">
    <div id="test-root"></div>
  </div>

  <script is:inline>
window.TEST_CONFIG = {
  id: 'pdss',
  title: 'Шкала тяжести панического расстройства (PDSS-SR)',
  description: 'PDSS (Shear et al.) — профильный клинический инструмент по паническому расстройству: он оценивает не только сами приступы, но и тревогу ожидания, избегание и влияние на жизнь. Панической атакой считается внезапный приступ сильного страха или дискомфорта с телесными симптомами (сердцебиение, нехватка воздуха, головокружение, дрожь). Отвечайте про ПОСЛЕДНЮЮ НЕДЕЛЮ.',
  minutes: '2–3',
  scoring: 'sum',
  valueStart: 0,
  resultNote: 'Сумма от 0 до 28. Ориентиры: 0–5 — норма или единичные эпизоды; 6–9 — лёгкое паническое расстройство; 10–13 — умеренное; 14 и выше — выраженное, помощь специалиста желательна не откладывая. Хорошая новость, которую я повторяю каждому пациенту: паническое расстройство — одно из самых благодарных в лечении. Паническая атака, какой бы ужасающей ни казалась, не опасна для жизни и хорошо поддаётся терапии — а часто требует и мягкой медикаментозной поддержки на время. Это скрининг, а не диагноз.',
  scaleLabels: ['0','1','2','3','4'],
  bands: [
    { max: 6,  label: 'норма', color: '#7fb069', pos: { label: 'норма', color: '#7fb069' } },
    { max: 10, label: 'лёгкая степень', color: '#c9a26b', pos: { label: 'лёгкая степень', color: '#c9a26b' } },
    { max: 14, label: 'умеренная степень', color: '#d98e4a', pos: { label: 'умеренная степень', color: '#d98e4a' } },
    { max: 99, label: 'выраженная степень', color: '#c95b5b', pos: { label: 'выраженная степень', color: '#c95b5b' } }
  ],
  scales: {
    tot: { name: 'Тяжесть панического расстройства', group: '', items: [1,2,3,4,5,6,7] }
  },
  itemsFull: true,
  items: [
{ text: "ЧАСТОТА ПРИСТУПОВ. Сколько панических и ограниченно-симптомных приступов было у вас за прошедшую неделю?", opts: ["Ни одного","Лёгкие: не чаще 1 в неделю","Умеренные: чаще 1 в неделю, но не каждый день","Тяжёлые: почти ежедневно","Крайне тяжёлые: несколько раз в день почти каждый день"] },
{ text: "ТЯЖЕСТЬ ПРИСТУПОВ. Насколько тягостными были приступы, пока длились?", opts: ["Приступов не было","Лёгкий дискомфорт","Умеренный дистресс, но контролируемый","Сильный дистресс, трудно контролировать","Крайне сильный, почти постоянный дистресс"] },
{ text: "ТРЕВОГА ОЖИДАНИЯ. Как много времени вы провели в тревоге и беспокойстве о том, что случится следующий приступ?", opts: ["Совсем не тревожился","Изредка или слабо","Часто или умеренно","Очень часто или сильно","Почти постоянно и крайне сильно"] },
{ text: "ИЗБЕГАНИЕ СИТУАЦИЙ. Избегали ли вы мест или ситуаций (транспорт, толпа, магазины, выход из дома) из страха приступа?", opts: ["Не избегал","Изредка избегал","Часто избегал","Очень часто, это заметно ограничивало","Избегал настолько, что почти не выходил / не мог функционировать"] },
{ text: "ИЗБЕГАНИЕ ОЩУЩЕНИЙ. Избегали ли вы действий, вызывающих «пугающие» телесные ощущения (спорт, кофе, волнующие фильмы, секс)?", opts: ["Не избегал","Изредка избегал","Часто избегал","Очень часто","Избегал практически полностью"] },
{ text: "ВЛИЯНИЕ НА РАБОТУ. Насколько приступы и тревога мешали вашей работе или домашним обязанностям?", opts: ["Не мешали","Немного, но справлялся","Заметно мешали, но справлялся","Сильно ухудшили работоспособность","Не мог работать / выполнять обязанности"] },
{ text: "ВЛИЯНИЕ НА ОТНОШЕНИЯ. Насколько приступы и тревога мешали общению с близкими, друзьями, вашей социальной жизни?", opts: ["Не мешали","Немного","Заметно мешали","Сильно нарушили отношения и общение","Отношения и общение практически разрушены"] }
  ].map(function (o, i) { return { n: i + 1, text: o.text, opts: o.opts }; })
};
  </script>
  <script is:inline src="/test-engine.js"></script>
</Base>
